<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Story image/video full-screen -->
    <ImageView
        android:id="@+id/ivStory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#1A1A1A" />

    <!-- Progress bar at top -->
    <ProgressBar
        android:id="@+id/progressStory"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:layout_marginTop="44dp"
        android:paddingHorizontal="8dp"
        android:progressTint="#FFFFFF"
        android:progressBackgroundTint="#66FFFFFF" />

    <!-- Top bar: avatar + name + time + MORE + close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:paddingTop="52dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">
            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_avatar" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- شارة الستيلث -->
                <TextView
                    android:id="@+id/tvStealthBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="🔕 مخفي"
                    android:textColor="#FFD700"
                    android:textSize="11sp"
                    android:background="#AA000000"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="2dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- زرار الخيارات ⋮ -->
        <ImageView
            android:id="@+id/ivMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_more"
            android:tint="#FFFFFF"
            android:padding="8dp"
            android:layout_marginEnd="4dp" />

        <!-- زرار الإغلاق -->
        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Caption + reply at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/btnReply"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_story_reply"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="رد على القصة..."
                android:textColor="#FFFFFF"
                android:textColorHint="#AAFFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
