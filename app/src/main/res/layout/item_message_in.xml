<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingVertical="2dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_in"
        android:paddingHorizontal="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <!-- Sender name (للجروبات) -->
        <TextView
            android:id="@+id/tvSender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/tg_blue"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"
            android:visibility="gone" />

        <!-- Forward indicator -->
        <TextView
            android:id="@+id/tvForward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/tg_blue"
            android:textSize="12sp"
            android:textStyle="italic"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <!-- Reply bubble -->
        <LinearLayout
            android:id="@+id/layoutReply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_reply"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="@color/tg_blue"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvReply"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Message text -->
        <TextView
            android:id="@+id/tvText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.2" />

        <!-- Time -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textColor="@color/text_time"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

        <!-- ivStatus not used for incoming -->
        <ImageView
            android:id="@+id/ivStatus"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
